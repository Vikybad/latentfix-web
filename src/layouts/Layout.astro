---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<meta name="description" content="LatentFix | Professional Node.js Performance Consulting" />
	</head>
	<body class="antialiased">
		<slot />
	</body>
</html>