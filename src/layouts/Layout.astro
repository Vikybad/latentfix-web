---
import { SEO } from "astro-seo";
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;

// Define the Schema.org data for better SEO visibility
const schemaData = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "LatentFix",
  "image": "https://latentfix.com/BrandLogo.png",
  "@id": "https://latentfix.com",
  "url": "https://latentfix.com",
  "telephone": "+919499424304",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "",
    "addressLocality": "Gurugram",
    "addressRegion": "Haryana",
    "postalCode": "",
    "addressCountry": "IN"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 28.4595,
    "longitude": 77.0266
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday", "Tuesday", "Wednesday", "Thursday", "Friday"
    ],
    "opens": "09:00",
    "closes": "18:00"
  },
  "sameAs": [
    "https://linkedin.com/in/vikrambadesara",
    "https://x.com/latentfix"
  ],
  "founder": {
    "@type": "Person",
    "name": "Vikram Badesara"
  },
  "description": "Expert performance engineering for React, React Native, and Node.js. Specializing in Express REST API optimization, SQL query tuning, and high-scale infrastructure."
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/BrandLogo.png" />

		<SEO
			title={title}
			description="LatentFix: Professional performance engineering for Node.js, React, and React Native. We optimize Express REST APIs, SQL queries, and analytics tracking to reduce latency for high-growth startups."
			canonical="https://latentfix.com"
			openGraph={{
				basic: {
					title: "LatentFix | Node.js & React Performance Engineering",
					type: "website",
					image: "https://latentfix.com/BrandLogo.webp",
				}
			}}
			twitter={{
				creator: "@vikybad",
				site: "@latentfix",
				card: "summary_large_image",
			}}
			extend={{
				meta: [
					{ name: "keywords", content: "Node.js Performance, React Optimization, React Native Speed, Express API Latency, SQL Query Optimization, LatentFix, Performance Engineering Gurugram, REST API Scaling, Analytics Tracking, Full-stack scalability" },
					{ name: "author", content: "Vikram Badesara" },
				],
			}}
		/>

		<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
	</head>
	<body class="antialiased">
		<slot />
	</body>
</html>